# TradeTrace environment configuration.
# Copy to .env and fill in real values. .env is gitignored.

# --- Qwen (strategy parsing + post-run report). Required to create new runs. ---
QWEN_API_KEY=
QWEN_BASE_URL=https://hackathon.bitgetops.com/v1
QWEN_MODEL=qwen3.6-plus

# --- Bitget GetAgent / Playbook (backtest). Required to create new runs. ---
# The Playbook control-plane (upload/run/poll) needs a DEDICATED Playbook API Key
# as the `ACCESS-KEY` header — NOT a regular Bitget OpenAPI key.
# How to get it: log into the Playbook page with your registered Bitget UID,
# click "Create Agent", follow the sub-account flow, and copy the Playbook API Key.
# A regular Bitget API key returns 401 ("No user found for the provided playbook_key");
# an inactive/un-whitelisted Playbook principal returns 403 ("Principal not found or inactive").
PLAYBOOK_ACCESS_KEY=
# Fallback only: used if PLAYBOOK_ACCESS_KEY is unset. A regular Bitget key here
# will typically be rejected by the Playbook endpoints (see above).
BITGET_API_KEY=
# Reserved for signed endpoints; NOT read by the current code path.
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# --- Telegram (optional). Leave empty to run the Web UI without the bot. ---
TELEGRAM_BOT_TOKEN=

# --- App URL (optional). Used to build run links returned by the Telegram API. ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
