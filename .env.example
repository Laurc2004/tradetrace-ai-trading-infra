# TradeTrace environment configuration.
# Copy to .env and fill in real values. .env is gitignored.

# --- Qwen (strategy parsing + post-run report). Required to create new runs. ---
# The hackathon issues a Qwen API key (works with Cursor / Codex; routed through
# the Bitget proxy at the base URL below). You can also use your own Qwen key.
QWEN_API_KEY=
QWEN_BASE_URL=https://hackathon.bitgetops.com/v1
QWEN_MODEL=qwen3.6-plus

# --- Backtest data source. ---
# TradeTrace runs a deterministic local backtest over REAL historical klines
# pulled from Bitget's PUBLIC market-data endpoints
# (https://api.bitget.com/api/v2/spot/market/candles) — the same endpoints the
# Agent Hub `spot_get_candles` / `futures_get_candles` skills call. These are
# public: NO Bitget API key is required for backtesting.

# --- Telegram (optional). Leave empty to run the Web UI without the bot. ---
TELEGRAM_BOT_TOKEN=

# --- App URL (optional). Used to build run links returned by the Telegram API. ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
